{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_/backend|assets/|svg/|favicon.ico|robots.txt|sitemap.xml|novablog-linkedin-thumbnail.png).*)",
      "destination": "/index.html"
    }
  ]
}
